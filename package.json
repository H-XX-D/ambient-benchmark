{
  "name": "ambient-benchmark",
  "version": "0.1.0",
  "description": "AMBIENT: Agentic Memory Benchmark. Baseline-Isolated Evaluation, Normalized Tiers. A substrate-neutral benchmark for what a memory system adds to a model.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bench": "node --disable-warning=ExperimentalWarning suites/ambient/ambient-bench.mjs",
    "bench:suite": "node --disable-warning=ExperimentalWarning suites/ambient/ambient-suite.mjs",
    "bench:contradiction": "node --disable-warning=ExperimentalWarning suites/ambient/ambient-contradiction-corpus.mjs --tier full",
    "bench:contradiction:lite": "node --disable-warning=ExperimentalWarning suites/ambient/ambient-contradiction-corpus.mjs --tier lite",
    "bench:injection": "node --disable-warning=ExperimentalWarning suites/ambient/ambient-injection-suite.mjs",
    "adapter:baseline": "node adapters/baseline-pull-server.mjs",
    "adapter:recall": "node adapters/recall_adapter.mjs",
    "adapter:ai-memory": "node adapters/ai-memory-http-adapter.mjs",
    "adapter:projectmem": "node adapters/projectmem-cli-adapter.mjs",
    "adapter:simple-memory": "node adapters/simple-memory-cli-adapter.mjs",
    "adapter:agent-recall": "node adapters/agent-recall-python-adapter.mjs",
    "adapter:total-agent-memory": "node adapters/total-agent-memory-sqlite-adapter.mjs",
    "adapter:claude-memory-mcp": "node adapters/claude-memory-mcp-cli-adapter.mjs",
    "adapter:engram": "node adapters/engram-cli-adapter.mjs",
    "adapter:mcp-local-memory": "node adapters/mcp-local-memory-sqlite-adapter.mjs",
    "adapter:sqlite-memory-mcp": "node adapters/sqlite-memory-mcp-sqlite-adapter.mjs",
    "adapter:mcp-memory-keeper": "node adapters/mcp-memory-keeper-sqlite-adapter.mjs",
    "adapter:local-memory-mcp": "node adapters/local-memory-mcp-sqlite-adapter.mjs",
    "adapter:mcp-memory-sqlite": "node adapters/mcp-memory-sqlite-adapter.mjs",
    "adapter:agent-memory": "node adapters/agent-memory-sqlite-adapter.mjs",
    "adapter:agent-memory-mcp": "node adapters/agent-memory-mcp-sqlite-adapter.mjs",
    "adapter:mem0": "node adapters/mem0-http-adapter.mjs",
    "adapter:cognee": "node adapters/cognee-python-adapter.mjs",
    "adapter:graphiti": "node adapters/graphiti-python-adapter.mjs",
    "adapter:langmem": "node adapters/langmem-python-adapter.mjs",
    "adapter:memoryos": "node adapters/memoryos-python-adapter.mjs",
    "adapter:local-memory-mcp-rust": "node adapters/local-memory-mcp-rust-sqlite-adapter.mjs",
    "adapter:claude-memory-ruby": "node adapters/claude-memory-ruby-sqlite-adapter.mjs",
    "adapter:mcp-memory-sqlite-personal": "node adapters/mcp-memory-sqlite-personal-adapter.mjs",
    "corpus:injection": "node corpora/build-injection-corpus.mjs",
    "verify": "npm run verify:clean && npm run verify:clean:artifact",
    "verify:clean": "node --disable-warning=ExperimentalWarning scripts/verify-clean-loop.mjs --once --summary-json results/clean-verification.json",
    "verify:clean:artifact": "node --disable-warning=ExperimentalWarning scripts/check-clean-verification.mjs",
    "verify:clean:loop": "node --disable-warning=ExperimentalWarning scripts/verify-clean-loop.mjs --summary-json results/clean-verification.json",
    "verify:mal:standing-programs": "node --disable-warning=ExperimentalWarning scripts/verify-named-standing-program-mal.mjs",
    "verify:mal:watchdogs": "npm run verify:mal:standing-programs",
    "verify:adapters:matrix": "node --disable-warning=ExperimentalWarning scripts/verify-cross-adapter-matrix.mjs",
    "verify:adapters:matrix:artifact": "node --disable-warning=ExperimentalWarning scripts/check-cross-adapter-matrix.mjs",
    "verify:adapters:matrix:extended": "node --disable-warning=ExperimentalWarning scripts/verify-cross-adapter-matrix.mjs --include-optional --allow-skips --out results/cross-adapter-matrix-extended.json",
    "verify:adapters:prereqs": "node --disable-warning=ExperimentalWarning scripts/check-optional-adapter-prereqs.mjs",
    "judge:adapters:matrix": "node --disable-warning=ExperimentalWarning scripts/judge-cross-adapter-matrix.mjs",
    "judge:adapters:matrix:artifact": "node --disable-warning=ExperimentalWarning scripts/check-cross-adapter-grades.mjs",
    "bench:adapters:grade": "npm run judge:adapters:matrix",
    "verify:adapters:judge": "node --disable-warning=ExperimentalWarning scripts/verify-cross-adapter-judge.mjs && node --disable-warning=ExperimentalWarning scripts/check-cross-adapter-grades.mjs --artifact results/judge-smoke-grade-summary.json --expect-adapters baseline-pull --expect-model mock-judge --expect-rows 8 --require-all-passed",
    "verify:adapters:grade:pipeline": "node --disable-warning=ExperimentalWarning scripts/verify-cross-adapter-grade-pipeline.mjs",
    "bench:paid:prelim": "node --disable-warning=ExperimentalWarning scripts/verify-cross-adapter-grade-pipeline.mjs --use-external-model --use-external-judge --judge-model gpt-5.4-nano --per-ability 3 --limit 0 --matrix results/cross-adapter-paid-prelim-matrix.json --out results/cross-adapter-paid-prelim-summary.json",
    "verify:adapter:baseline": "node --disable-warning=ExperimentalWarning scripts/verify-baseline-adapter-wire.mjs",
    "verify:adapter:ai-memory": "node --disable-warning=ExperimentalWarning scripts/verify-ai-memory-adapter-bridge.mjs",
    "verify:adapter:projectmem": "node --disable-warning=ExperimentalWarning scripts/verify-projectmem-adapter-bridge.mjs",
    "verify:adapter:simple-memory": "node --disable-warning=ExperimentalWarning scripts/verify-simple-memory-adapter-bridge.mjs",
    "verify:adapter:agent-recall": "node --disable-warning=ExperimentalWarning scripts/verify-agent-recall-adapter-bridge.mjs",
    "verify:adapter:total-agent-memory": "node --disable-warning=ExperimentalWarning scripts/verify-total-agent-memory-adapter-bridge.mjs",
    "verify:adapter:claude-memory-mcp": "node --disable-warning=ExperimentalWarning scripts/verify-claude-memory-mcp-adapter-bridge.mjs",
    "verify:adapter:engram": "node --disable-warning=ExperimentalWarning scripts/verify-engram-adapter-bridge.mjs",
    "verify:adapter:mcp-local-memory": "node --disable-warning=ExperimentalWarning scripts/verify-mcp-local-memory-adapter-bridge.mjs",
    "verify:adapter:sqlite-memory-mcp": "node --disable-warning=ExperimentalWarning scripts/verify-sqlite-memory-mcp-adapter-bridge.mjs",
    "verify:adapter:mcp-memory-keeper": "node --disable-warning=ExperimentalWarning scripts/verify-mcp-memory-keeper-adapter-bridge.mjs",
    "verify:adapter:local-memory-mcp": "node --disable-warning=ExperimentalWarning scripts/verify-local-memory-mcp-adapter-bridge.mjs",
    "verify:adapter:mcp-memory-sqlite": "node --disable-warning=ExperimentalWarning scripts/verify-mcp-memory-sqlite-adapter-bridge.mjs",
    "verify:adapter:agent-memory": "node --disable-warning=ExperimentalWarning scripts/verify-agent-memory-adapter-bridge.mjs",
    "verify:adapter:agent-memory-mcp": "node --disable-warning=ExperimentalWarning scripts/verify-agent-memory-mcp-adapter-bridge.mjs",
    "verify:adapter:mem0": "node --disable-warning=ExperimentalWarning scripts/verify-mem0-adapter-bridge.mjs",
    "verify:adapter:cognee": "node --disable-warning=ExperimentalWarning scripts/verify-cognee-adapter-bridge.mjs",
    "verify:adapter:graphiti": "node --disable-warning=ExperimentalWarning scripts/verify-graphiti-adapter-bridge.mjs",
    "verify:adapter:langmem": "node --disable-warning=ExperimentalWarning scripts/verify-langmem-adapter-bridge.mjs",
    "verify:adapter:memoryos": "node --disable-warning=ExperimentalWarning scripts/verify-memoryos-adapter-bridge.mjs",
    "verify:adapter:local-memory-mcp-rust": "node --disable-warning=ExperimentalWarning scripts/verify-local-memory-mcp-rust-adapter-bridge.mjs",
    "verify:adapter:claude-memory-ruby": "node --disable-warning=ExperimentalWarning scripts/verify-claude-memory-ruby-adapter-bridge.mjs",
    "verify:adapter:mcp-memory-sqlite-personal": "node --disable-warning=ExperimentalWarning scripts/verify-mcp-memory-sqlite-personal-adapter-bridge.mjs",
    "bench:suite:1b": "node --disable-warning=ExperimentalWarning suites/ambient/ambient-suite-1b.mjs",
    "bench:1b-hard": "node --disable-warning=ExperimentalWarning suites/ambient/ambient-1b-hard.mjs"
  }
}
